<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="20dp"
    app:cardBackgroundColor="@color/aquatrack_surface"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/aquatrack_outline"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/tankNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:textColor="@color/aquatrack_card_title"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Reef Paradise" />

        <TextView
            android:id="@+id/tankMetaText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/aquatrack_card_muted"
            android:textSize="12sp"
            tools:text="Saltwater"
            app:layout_constraintStart_toStartOf="@id/tankNameText"
            app:layout_constraintTop_toBottomOf="@id/tankNameText" />

        <TextView
            android:id="@+id/tankTempText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/aquatrack_card_accent"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="90L  ·  20.0°C"
            app:layout_constraintStart_toStartOf="@id/tankNameText"
            app:layout_constraintTop_toBottomOf="@id/tankMetaText" />

        <TextView
            android:id="@+id/tankCleanedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/aquatrack_card_muted"
            android:textSize="11sp"
            tools:text="Cleaned 3 days ago"
            app:layout_constraintStart_toStartOf="@id/tankNameText"
            app:layout_constraintTop_toBottomOf="@id/tankTempText" />

        <!-- Shown only when cleaning is overdue -->
        <TextView
            android:id="@+id/tankOverdueBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:background="@drawable/bg_overdue_chip"
            android:paddingStart="7dp"
            android:paddingTop="2dp"
            android:paddingEnd="7dp"
            android:paddingBottom="2dp"
            android:text="@string/tank_overdue_label"
            android:textColor="@color/aquatrack_warning"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/tankNameText"
            app:layout_constraintTop_toBottomOf="@id/tankCleanedText" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/tankImageView"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_tank_glow"
            android:contentDescription="@string/tank_image"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.AquaTrack.RoundedImage"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tankFishCountText"
            android:layout_width="wrap_content"
            android:layout_height="19dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:text="@string/stat_fish"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tankImageView" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>

