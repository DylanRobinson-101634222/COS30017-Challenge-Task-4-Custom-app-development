<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aquatrack_background">

    <FrameLayout
        android:id="@+id/heroCard"
        android:layout_width="0dp"
        android:layout_height="@dimen/tank_detail_hero_height"
        android:background="@drawable/bg_header_aqua"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/tankHeaderImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/tank_image"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <View
            android:id="@+id/tankHeaderOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66264E57"
            android:visibility="gone" />

        <View
            android:layout_width="300dp"
            android:layout_height="220dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="30dp"
            android:alpha="0.30"
            android:background="@drawable/bg_wave_layer" />

        <View
            android:layout_width="220dp"
            android:layout_height="160dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="-20dp"
            android:alpha="0.25"
            android:background="@drawable/bg_wave_layer" />

        <View
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_header_bottom_inset_shadow" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="74dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tankNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tank_name_placeholder"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tankSubMetaText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/tank_sub_meta_placeholder"
                android:textColor="#97F0FF"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#DBF2F5"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <TextView
                    android:id="@+id/reminderButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="8dp"
                    android:text="@string/reminder_summary_default"
                    android:textColor="#14616B"
                    android:textSize="12sp" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <ImageButton
            android:id="@+id/backTankDetailButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="14dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_back_button_scrim"
            android:contentDescription="@string/action_back"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back_24"
            app:tint="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/editTankButton"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"
            android:text="@string/action_edit"
            android:textAllCaps="false"
            android:textColor="#001F24"
            android:textSize="13sp"
            app:backgroundTint="#97F0FF"
            app:cornerRadius="16dp" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/aquatrack_surface"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/heroCard">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/aquatrack_chip_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/fishCountStatText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_count_default"
                    android:textColor="@color/aquatrack_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_fish"
                    android:textColor="@color/aquatrack_card_muted"
                    android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/aquatrack_chip_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/cleanedStatText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_today"
                    android:textColor="@color/aquatrack_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_cleaned"
                    android:textColor="@color/aquatrack_card_muted"
                    android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/aquatrack_chip_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/nextCleanStatText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_next_clean_default"
                    android:textColor="@color/aquatrack_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_next_clean"
                    android:textColor="@color/aquatrack_card_muted"
                    android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <TextView
        android:id="@+id/fishSectionTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="20dp"
        android:text="@string/fish_in_tank_title"
        android:textColor="@color/aquatrack_on_surface"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statsRow" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/fishRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="20dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toTopOf="@id/buttonRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fishSectionTitle" />

    <TextView
        android:id="@+id/emptyFishStateText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:gravity="center"
        android:padding="@dimen/content_spacing_large"
        android:text="@string/no_fish_yet"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/buttonRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fishSectionTitle" />

    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="@dimen/tank_detail_button_bottom_margin"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addFishButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="48dp"
            android:text="@string/add_fish_short"
            android:textAllCaps="false"
            android:textColor="#001F24"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="@color/aquatrack_primary"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/markCleanedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:minHeight="48dp"
            android:text="@string/mark_cleaned"
            android:textAllCaps="false"
            android:textColor="#14616B"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="#DBF2F5"
            app:cornerRadius="18dp"
            app:strokeColor="#591F737A"
            app:strokeWidth="1dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
